# Normalize all text files to LF on checkout and commit (cross-platform).
# Git honors this even when a Windows user has core.autocrlf=true.
* text=auto eol=lf

# Binary files are not subject to line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp4 binary
*.mp3 binary
*.wav binary
*.flac binary
*.aac binary
*.ogg binary
*.webm binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.bin binary
*.dat binary
*.safetensors binary
*.onnx binary
*.pt binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
