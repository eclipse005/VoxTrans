{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoxTrans",
  "version": "1.0.0",
  "identifier": "com.voxtrans.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VoxTrans - dabao005 - www.52pojie.cn",
        "width": 1480,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/fireredvad.exe",
      "bin/demucs.exe",
      "bin/yt-dlp.exe",
      "bin/ffmpeg.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
