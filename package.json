{
  "name": "voxtrans",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:release": "powershell -ExecutionPolicy Bypass -File .\\build-release.ps1",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:types": "cargo test -p voxtrans ts_export_tests && mkdir -p src/generated/bindings && cp src-tauri/bindings/*.ts src/generated/bindings/",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:cuda": "powershell -ExecutionPolicy Bypass -File .\\scripts\\tauri-cuda.ps1 dev",
    "tauri:build:cuda": "powershell -ExecutionPolicy Bypass -File .\\scripts\\tauri-cuda.ps1 build",
    "cargo:check:cuda": "powershell -ExecutionPolicy Bypass -File .\\scripts\\tauri-cuda.ps1 check"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  }
}
